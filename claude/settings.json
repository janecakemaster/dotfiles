{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:*)",
      "Read(//var/folders/*)",
      "Bash(gh *)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jane/.claude/hooks/check-settings-junk.sh",
            "timeout": 5,
            "statusMessage": "Checking settings..."
          },
          {
            "type": "command",
            "command": "/Users/jane/.claude/hooks/top-todos.sh",
            "timeout": 5,
            "statusMessage": "Loading todos..."
          },
          {
            "type": "command",
            "command": "/Users/jane/.claude/hooks/plugin-reminder.sh",
            "timeout": 3,
            "statusMessage": "Loading available plugins..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jane/.claude/hooks/git-warnings.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jane/.claude/hooks/dave-notes-reminder.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "/Users/jane/.claude/hooks/format-markdown.sh",
            "timeout": 10,
            "statusMessage": "Formatting..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jane/.claude/hooks/format-markdown.sh",
            "timeout": 10,
            "statusMessage": "Formatting..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jane/.claude/hooks/context-mode-reminder.sh",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "mcp__claude_ai_Notion__notion-create-pages|mcp__claude_ai_Notion__notion-update-page",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jane/.claude/hooks/notion-contributions-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jane/.claude/hooks/precompact-save-context.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r '.workspace.current_dir // .cwd'); model=$(echo \"$input\" | jq -r '.model.display_name // \"\"'); used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); dir=$(basename \"$cwd\"); branch=$(git -C \"$cwd\" --no-optional-locks symbolic-ref --short HEAD 2>/dev/null); parts=\"☁  $dir\"; [ -n \"$branch\" ] && parts=\"$parts [$branch]\"; [ -n \"$model\" ] && parts=\"$parts | $model\"; [ -n \"$used\" ] && parts=\"$parts | ctx: $(printf '%.0f' \"$used\")%\"; printf '%s' \"$parts\""
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context-mode@context-mode": true,
    "skill-creator@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/claude-context-mode"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "high",
  "additionalDirectories": [
    "/Users/jane/Desktop/work-notes",
    "/Users/jane/weekend-repos"
  ],
  "feedbackSurveyState": {
    "lastShownTime": 1753923207992
  },
  "mcp": {
    "servers": {
      "weekend-docs-mcp": {
        "command": "node",
        "args": [
          "/Users/jane/weekend-repos/weekend-docs-mcp/dist/index.js"
        ],
        "cwd": "/Users/jane/weekend-repos/weekend-docs-mcp"
      }
    }
  }
}
